# ===== zen-ref-agent .env example =====
# 1) Скопируйте этот файл в .env
# 2) Вставьте свои значения

# Путь к SQLite-файлу. Можно оставить как есть.
DB_PATH=./zen_ref_agent.db

# OpenAI (для генерации идей/черновиков).
# Если ключ пустой, проект не упадет — включится fallback-режим.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Telegram (нужно для команды send-telegram)
TELEGRAM_BOT_TOKEN=123456789:AAExampleBotToken
TELEGRAM_CHAT_ID=123456789
